<%# Locals: book (required), user (required).
    Inline chip cluster showing which of the user's shelves contain this book.
    Wrapped in a turbo_frame so shelf_entries#toggle can replace it after a
    membership change. Includes the "+ Add to shelf" button that toggles the
    picker panel. %>
<%= turbo_frame_tag dom_id(book, :shelves) do %>
  <% member_shelves = book.shelves_for(user).by_name.to_a %>
  <div data-controller="shelf-picker" class="relative inline-flex items-start flex-wrap gap-1.5">
    <% member_shelves.each do |shelf| %>
      <%= link_to shelf, class: "inline-flex items-center gap-1 px-2 py-1 bg-stone-100 hover:bg-stone-200 text-stone-700 text-xs rounded-full border border-stone-200 transition" do %>
        <%= shelf.name %>
        <% if shelf.sync_to_kobo %>
          <svg class="w-3 h-3 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 12l3-3m0 0l3 3m-3-3v12M21 12l-3 3m0 0l-3-3m3 3V3"/>
          </svg>
        <% end %>
      <% end %>
    <% end %>

    <button type="button"
            data-action="shelf-picker#toggle"
            class="inline-flex items-center gap-1 px-2 py-1 text-xs rounded-full border border-dashed border-stone-300 text-stone-600 hover:text-stone-900 hover:border-stone-500 transition cursor-pointer">
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      Add to shelf
    </button>

    <div data-shelf-picker-target="panel"
         class="hidden absolute top-full left-0 mt-2 w-72 bg-white border border-stone-200 rounded-md shadow-lg z-10">
      <%= render "shelves/picker_panel", book: book, user: user %>
    </div>
  </div>
<% end %>
