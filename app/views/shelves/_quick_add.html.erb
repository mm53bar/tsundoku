<%# Locals: book (required), user (required), all_shelves (optional),
    member_ids (optional).

    Floating "+ shelf" button anchored on a book-card cover. The
    Floating UI–backed popover handles positioning (auto-flip when
    the card is near the viewport edge), outside-click + Escape
    dismissal, and mutex coordination with other popovers (opening
    one closes any other). Same panel content the chip_row picker
    uses on book#show. %>
<%
  on_a_shelf = local_assigns[:member_ids].present? && local_assigns[:member_ids].any?
  button_classes =
    if on_a_shelf
      # Amber matches the "On your Kobo" pill — signals "already curated."
      "inline-flex items-center justify-center w-6 h-6 rounded-full bg-amber-100 hover:bg-amber-200 focus:bg-amber-200 border border-amber-300 text-amber-700 hover:text-amber-900 shadow-sm transition cursor-pointer"
    else
      "inline-flex items-center justify-center w-6 h-6 rounded-full bg-white/70 hover:bg-white focus:bg-white border border-stone-200/70 hover:border-stone-300 text-stone-600 hover:text-stone-900 shadow-sm transition cursor-pointer"
    end
%>

<%= render "shared/components/popover/popover", placement: "bottom-end", max_width: 256 do %>
  <button type="button"
          data-popover-target="button"
          title="<%= on_a_shelf ? "On a shelf — click to manage" : "Add to shelf" %>"
          aria-label="<%= on_a_shelf ? "Manage this book's shelves" : "Add this book to a shelf" %>"
          class="<%= button_classes %>">
    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
    </svg>
  </button>

  <template data-popover-target="content">
    <%= render "shelves/picker_panel",
          book: book,
          user: user,
          **local_assigns.slice(:all_shelves, :member_ids) %>
  </template>
<% end %>
