<%# Locals: book (required), user (required), all_shelves (optional),
    member_ids (optional). all_shelves and member_ids override the
    per-card queries — pass them from the index so a grid of cards
    doesn't fan out one query per book. Without the overrides we fall
    back to the original per-render lookup so the existing chip_row
    call sites (book#show) work unchanged.

    No outer turbo_frame; the rows below are replaced individually via
    dom_id'd targets when the toggle endpoint streams back. %>
<% all_shelves = local_assigns[:all_shelves] || user.shelves.by_name %>
<div class="max-h-72 overflow-y-auto py-1">
  <% if all_shelves.any? %>
    <% member_ids = local_assigns[:member_ids] || book.shelves_for(user).pluck(:id).to_set %>
    <% all_shelves.each do |shelf| %>
      <%= render "shelves/membership_row", book: book, shelf: shelf, on_shelf: member_ids.include?(shelf.id) %>
    <% end %>
  <% else %>
    <p class="px-3 py-2 text-xs text-stone-500">No shelves yet.</p>
  <% end %>
</div>
<div class="px-3 py-2 border-t border-stone-100">
  <%= link_to "+ New shelf", new_shelf_path, class: "text-xs text-amber-700 hover:text-amber-800" %>
</div>
