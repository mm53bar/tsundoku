<% content_for :title, @shelf.name %>

<div class="mb-6">
  <%= link_to shelves_path, class: "inline-flex items-center gap-1 text-sm text-stone-600 hover:text-stone-900" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Shelves
  <% end %>
</div>

<div class="flex items-start justify-between gap-4 mb-2">
  <h1 class="text-3xl font-semibold tracking-tight"><%= @shelf.name %></h1>

  <div class="shrink-0 flex items-center gap-2">
    <%= link_to "Edit", edit_shelf_path(@shelf),
          class: "inline-flex items-center px-3 py-1.5 bg-white border border-stone-300 text-stone-700 text-sm font-medium rounded-md hover:bg-stone-50 transition" %>
    <%= button_to @shelf,
          method: :delete,
          form: { data: { turbo_confirm: "Delete '#{@shelf.name}'?" } },
          class: "inline-flex items-center px-3 py-1.5 bg-white border border-stone-300 text-stone-700 text-sm font-medium rounded-md hover:bg-red-50 hover:border-red-200 hover:text-red-700 transition cursor-pointer" do %>
      Delete
    <% end %>
  </div>
</div>

<p class="text-sm text-stone-600 mb-1"><%= pluralize(@books.size, "book") %></p>

<% if @shelf.description.present? %>
  <p class="text-sm text-stone-700 mb-4 max-w-2xl"><%= @shelf.description %></p>
<% end %>

<div class="mb-6">
  <%= render "shelves/sync_toggle", shelf: @shelf %>
</div>

<% if @books.empty? %>
  <div class="mt-8 bg-white border border-stone-200 rounded-lg p-8 text-center text-stone-600">
    <p class="text-sm">No books on this shelf yet.</p>
    <p class="text-xs mt-1">Add books by clicking the + on any book cover and selecting this shelf.</p>
  </div>
<% else %>
  <%# Removing a book uses the same + picker the rest of the site does:
      click the (amber) +, uncheck this shelf. Keeping the visual
      treatment of every cover identical across the site is more
      valuable than a dedicated "X" affordance that's a tap or two
      shorter — Mike's call. %>
  <div class="mt-6 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-6">
    <% @books.each do |book| %>
      <%= render "books/card",
            book: book,
            all_shelves: @user_shelves,
            member_ids: @shelf_member_ids_by_book[book.id] %>
    <% end %>
  </div>
<% end %>
