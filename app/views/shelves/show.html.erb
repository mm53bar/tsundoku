<% content_for :title, @shelf.name %>

<div class="mb-6">
  <%= link_to shelves_path, class: "inline-flex items-center gap-1 text-sm text-stone-600 hover:text-stone-900" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Shelves
  <% end %>
</div>

<div class="flex items-start justify-between gap-4 mb-2">
  <h1 class="text-3xl font-semibold tracking-tight"><%= @shelf.name %></h1>

  <div class="shrink-0 flex items-center gap-2">
    <%= link_to "Edit", edit_shelf_path(@shelf),
          class: "inline-flex items-center px-3 py-1.5 bg-white border border-stone-300 text-stone-700 text-sm font-medium rounded-md hover:bg-stone-50 transition" %>
    <%= button_to @shelf,
          method: :delete,
          form: { data: { turbo_confirm: "Delete '#{@shelf.name}'?" } },
          class: "inline-flex items-center px-3 py-1.5 bg-white border border-stone-300 text-stone-700 text-sm font-medium rounded-md hover:bg-red-50 hover:border-red-200 hover:text-red-700 transition cursor-pointer" do %>
      Delete
    <% end %>
  </div>
</div>

<p class="text-sm text-stone-600 mb-1"><%= pluralize(@books.size, "book") %></p>

<% if @shelf.description.present? %>
  <p class="text-sm text-stone-700 mb-4 max-w-2xl"><%= @shelf.description %></p>
<% end %>

<div class="mb-6">
  <%= render "shelves/sync_toggle", shelf: @shelf %>
</div>

<% if @books.empty? %>
  <div class="mt-8 bg-white border border-stone-200 rounded-lg p-8 text-center text-stone-600">
    <p class="text-sm">No books on this shelf yet.</p>
    <p class="text-xs mt-1">Add books from their detail pages — that flow is coming in the next update.</p>
  </div>
<% else %>
  <div class="mt-6 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-6">
    <% @books.each do |book| %>
      <div class="relative group/card">
        <%= render "books/card", book: book %>
        <%= button_to remove_book_shelf_path(@shelf, book_id: book.id),
              method: :delete,
              form: { data: { turbo_confirm: "Remove '#{book.title}' from this shelf?" }, class: "absolute top-2 right-2 opacity-0 group-hover/card:opacity-100 transition-opacity" },
              class: "flex items-center justify-center w-7 h-7 rounded-full bg-white/90 backdrop-blur-sm border border-stone-300 text-stone-600 hover:bg-red-50 hover:border-red-300 hover:text-red-700 shadow-sm cursor-pointer",
              title: "Remove from this shelf" do %>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
