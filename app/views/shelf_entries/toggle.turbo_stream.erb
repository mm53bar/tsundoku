<%# After a shelf-membership toggle, refresh two regions:
    1. The chip row above (chip appears/disappears + sync indicator)
    2. The row inside the picker panel (checkbox flips state)
    Both are turbo_frames anchored by dom_id, so this is a clean
    surgical replacement with no flicker. %>
<%= turbo_stream.replace dom_id(@book, :shelves) do %>
  <%= render "shelves/chip_row", book: @book, user: current_user %>
<% end %>
<%= turbo_stream.replace "membership_#{@shelf.id}_for_book_#{@book.id}" do %>
  <%= render "shelves/membership_row", book: @book, shelf: @shelf, on_shelf: @on_shelf %>
<% end %>
