<%# Locals: tasks (collection of Task.visible.order(:created_at)).
    Lives inside the Rails Blocks navbar dropdown content with id="tasks-tray".
    Updated in place via Turbo Stream from "tasks:active" (see Task#broadcast_update). %>
<div id="tasks_tray" class="text-sm">
  <% if tasks.any? %>
    <div class="px-3 py-2 border-b border-stone-200">
      <p class="text-xs uppercase tracking-wide text-stone-500"><%= pluralize(tasks.length, "task") %></p>
    </div>
    <ul class="max-h-96 overflow-y-auto divide-y divide-stone-100">
      <% tasks.each do |task| %>
        <li class="px-3 py-2 flex items-start gap-2">
          <div class="shrink-0 mt-0.5">
            <% if task.running? || task.queued? %>
              <svg class="animate-spin w-4 h-4 text-amber-700" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
              </svg>
            <% elsif task.pending_review? %>
              <svg class="w-4 h-4 text-amber-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            <% elsif task.succeeded? %>
              <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
            <% elsif task.failed? %>
              <svg class="w-4 h-4 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            <% end %>
          </div>

          <div class="flex-1 min-w-0">
            <p class="font-medium text-stone-900 truncate"><%= task.friendly_title %></p>
            <% if task.running? && task.progress_total.present? && task.progress_total.positive? %>
              <p class="text-xs text-stone-500"><%= task.progress_current %> / <%= task.progress_total %> (<%= task.progress_percentage %>%)</p>
            <% elsif task.pending_review? %>
              <p class="text-xs text-stone-500">Suggestions ready to review</p>
            <% elsif task.failed? && task.error_message.present? %>
              <p class="text-xs text-red-700 truncate"><%= task.error_message %></p>
            <% end %>
          </div>

          <% if task.pending_review? && task.subject.is_a?(Book) %>
            <%= link_to "Review", edit_book_path(task.subject, from_task: task.id),
                  data: { turbo_prefetch: false },
                  class: "shrink-0 text-xs px-2 py-1 bg-amber-600 text-white rounded hover:bg-amber-700 cursor-pointer" %>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="px-4 py-6 text-center text-stone-500">
      <p class="text-sm">No tasks in flight.</p>
      <p class="text-xs mt-1">Imports, enrichments, and ingests show up here.</p>
    </div>
  <% end %>
</div>
