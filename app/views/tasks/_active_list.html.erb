<div id="active_tasks">
  <% if tasks.any? %>
    <div class="bg-amber-50 border-b border-amber-200">
      <div class="container mx-auto px-6 py-3 space-y-2">
        <% tasks.each do |task| %>
          <%= render "tasks/card", task: task %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
