<% content_for :title, @author.name %>

<div class="mb-6">
  <%= link_to authors_path, class: "inline-flex items-center gap-1 text-sm text-stone-600 hover:text-stone-900" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Authors
  <% end %>
</div>

<div class="flex items-end justify-between gap-4 mb-8">
  <div>
    <h1 class="text-3xl font-semibold tracking-tight"><%= @author.name %></h1>
    <p class="text-stone-600 text-sm mt-1"><%= pluralize(@books.size, "book") %> in your library</p>
  </div>

  <% if @author.hardcover_url.present? %>
    <%= link_to @author.hardcover_url, target: "_blank", rel: "noopener",
          class: "inline-flex items-center gap-1.5 px-3 py-1.5 bg-white border border-stone-300 text-stone-700 text-sm font-medium rounded-md hover:bg-stone-50 transition" do %>
      View on Hardcover
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
      </svg>
    <% end %>
  <% end %>
</div>

<% if @books.empty? %>
  <p class="text-stone-500 text-sm">No books by this author yet.</p>
<% else %>
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-6">
    <% @books.each do |book| %>
      <%= render "books/card",
            book: book,
            all_shelves: @user_shelves,
            member_ids: @shelf_member_ids_by_book[book.id],
            starred_shelf_id: @starred_shelf_id %>
    <% end %>
  </div>
<% end %>

<% if @author.hardcover_slug.present? %>
  <section class="mt-12 pt-8 border-t border-stone-200">
    <h2 class="text-lg font-semibold text-stone-900 mb-1">More by <%= @author.name %> on Hardcover</h2>
    <p class="text-xs text-stone-500 mb-4">Books not yet in your library.</p>

    <%= turbo_frame_tag "more_by_author", src: more_books_author_path(@author), loading: "lazy" do %>
      <div class="flex items-center gap-3 text-sm text-stone-500 py-8 justify-center">
        <svg class="animate-spin w-5 h-5 text-amber-700" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
        </svg>
        <span>Loading more by <%= @author.name %>…</span>
      </div>
    <% end %>
  </section>
<% end %>
