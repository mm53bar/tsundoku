<% content_for :title, @author.name %>

<div class="mb-6">
  <%= link_to authors_path, class: "inline-flex items-center gap-1 text-sm text-stone-600 hover:text-stone-900" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Authors
  <% end %>
</div>

<div class="flex items-end justify-between gap-4 mb-8">
  <div>
    <h1 class="text-3xl font-semibold tracking-tight"><%= @author.name %></h1>
    <p class="text-stone-600 text-sm mt-1"><%= pluralize(@books.size, "book") %> in your library</p>
  </div>

  <% if @author.hardcover_url.present? %>
    <%= link_to @author.hardcover_url, target: "_blank", rel: "noopener",
          class: "inline-flex items-center gap-1.5 px-3 py-1.5 bg-white border border-stone-300 text-stone-700 text-sm font-medium rounded-md hover:bg-stone-50 transition" do %>
      View on Hardcover
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
      </svg>
    <% end %>
  <% end %>
</div>

<% if @books.empty? %>
  <p class="text-stone-500 text-sm">No books by this author yet.</p>
<% else %>
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-6">
    <% @books.each do |book| %>
      <%= render "books/card", book: book %>
    <% end %>
  </div>
<% end %>
