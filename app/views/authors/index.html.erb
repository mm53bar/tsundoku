<% content_for :title, "Authors" %>

<div data-controller="library-filter">
  <div class="mb-6">
    <h1 class="text-3xl font-semibold tracking-tight">Authors</h1>
    <p class="text-stone-600 text-sm mt-1">
      <span data-library-filter-target="count"><%= @authors.length %></span>
      <%= "author".pluralize(@authors.length) %>
    </p>
  </div>

  <% if @authors.any? %>
    <div class="mb-6">
      <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M10 18a8 8 0 100-16 8 8 0 000 16z"/>
        </svg>
        <input type="search"
               data-library-filter-target="input"
               data-action="input->library-filter#filter"
               placeholder="Filter authors…"
               autocomplete="off"
               class="w-full pl-10 pr-10 py-2 text-sm rounded-md border border-stone-300 bg-white focus:border-amber-600 focus:ring-amber-600 focus:outline-none">
        <button type="button"
                data-action="library-filter#clear"
                class="absolute right-2 top-1/2 -translate-y-1/2 p-1 text-stone-400 hover:text-stone-700 cursor-pointer">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-0.5">
      <% @authors.each do |author| %>
        <%= link_to author,
              data: {
                library_filter_target: "card",
                searchable: author.name.downcase
              },
              class: "flex items-baseline justify-between gap-3 px-3 py-2 rounded hover:bg-stone-100/80 transition" do %>
          <span class="font-medium text-stone-900 truncate"><%= author.name %></span>
          <span class="shrink-0 text-xs text-stone-500 font-mono"><%= author.books_count %></span>
        <% end %>
      <% end %>
    </div>

    <div data-library-filter-target="empty" hidden class="mt-6 bg-white border border-stone-200 rounded-lg p-8 text-center text-stone-600">
      <p class="text-sm">No authors match your filter.</p>
      <button type="button"
              data-action="library-filter#clear"
              class="mt-3 text-sm text-amber-700 hover:text-amber-800 underline cursor-pointer">
        Clear filter
      </button>
    </div>
  <% else %>
    <p class="text-stone-500 text-sm">No authors yet — import a Calibre library to populate this list.</p>
  <% end %>
</div>
