<!DOCTYPE html>
<html>
  <head>
    <title><%= safe_join([ content_for(:title).presence, "Tsundoku" ].compact, " · ") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Tsundoku">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-stone-50 text-stone-900 min-h-screen">
    <header class="border-b border-stone-200 bg-white">
      <div class="container mx-auto px-6 py-4 flex items-center justify-between gap-6">
        <div class="flex items-center gap-8">
          <%= link_to root_path, class: "flex items-center gap-2.5 text-xl font-semibold tracking-tight" do %>
            <%= image_tag "/favicon-96.png", alt: "Tsundoku", class: "w-10 h-10" %>
            <%# Wordmark hidden on phone — the favicon is enough of an
                identifier; the extra width matters when the hamburger
                and tray icons share a narrow row. %>
            <span class="hidden sm:inline">Tsundoku</span>
          <% end %>
          <% if signed_in? %>
            <% on_kobo_count = current_user.on_kobo_books.count %>
            <% in_library_group = %w[library authors series].include?(controller_name) && params[:filter].blank? %>
            <nav class="hidden sm:flex items-center gap-5 text-sm text-stone-600">
              <%# Library is a split-button: the label is a direct link to
                  Books (single-click), the chevron beside it opens a popover
                  with the catalog sub-views. Authors/Series are inside the
                  group because they're lenses on the same set of books, not
                  peers of the library itself. %>
              <div class="inline-flex items-center gap-0.5">
                <%= link_to "Library", root_path,
                      class: "hover:text-stone-900 #{"text-stone-900 font-medium" if in_library_group}" %>
                <%= render "shared/components/popover/popover", placement: "bottom-start", max_width: 180 do %>
                  <button type="button"
                          data-popover-target="button"
                          aria-label="More library views"
                          class="p-0.5 -my-0.5 text-stone-500 hover:text-stone-900 rounded cursor-pointer">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </button>
                  <template data-popover-target="content">
                    <nav class="py-1 min-w-[10rem]">
                      <%= link_to "Authors", authors_path,
                            class: "block px-4 py-1.5 text-sm text-stone-700 hover:bg-stone-100 hover:text-stone-900" %>
                      <%= link_to "Series",  series_index_path,
                            class: "block px-4 py-1.5 text-sm text-stone-700 hover:bg-stone-100 hover:text-stone-900" %>
                    </nav>
                  </template>
                <% end %>
              </div>

              <% if on_kobo_count.positive? %>
                <%= link_to root_path(filter: "on_kobo"),
                      class: "hover:text-stone-900 inline-flex items-center gap-1 #{"text-stone-900 font-medium" if params[:filter] == "on_kobo"}" do %>
                  On your Kobo
                  <span class="inline-flex items-center justify-center min-w-[1.25rem] px-1 text-xs rounded-full bg-amber-100 text-amber-800"><%= on_kobo_count %></span>
                <% end %>
              <% end %>
              <%= link_to "Shelves", shelves_path, class: "hover:text-stone-900 #{"text-stone-900 font-medium" if controller_name == "shelves"}" %>
              <%= link_to "Lists",   lists_path, class: "hover:text-stone-900 #{"text-stone-900 font-medium" if controller_name == "lists"}" %>
            </nav>
          <% end %>
        </div>
        <% if signed_in? %>
          <div class="flex-1 max-w-md hidden sm:block"
               data-controller="navbar-search"
               data-navbar-search-url-value="<%= search_path %>">
            <div class="relative">
              <input type="search"
                     placeholder="Search books..."
                     autocomplete="off"
                     data-navbar-search-target="input"
                     data-action="input->navbar-search#query focus->navbar-search#focus keydown->navbar-search#keydown"
                     class="w-full rounded-md border border-stone-200 bg-stone-50 px-3 py-1.5 text-sm placeholder:text-stone-400 focus:bg-white focus:border-stone-400 focus:outline-none">
              <div data-navbar-search-target="dropdown"
                   hidden
                   class="absolute top-full left-0 right-0 mt-1 bg-white border border-stone-200 rounded-md shadow-lg z-50 max-h-96 overflow-y-auto">
                <turbo-frame id="navbar-search-results" data-navbar-search-target="frame"></turbo-frame>
              </div>
            </div>
          </div>
        <% end %>
        <div class="flex items-center">
          <% if signed_in? %>
            <%# Help icon on desktop only — the Rails Blocks navbar's
                built-in hamburger (enabled below) handles mobile, and
                the mobile-menu-content panel includes a Help row. %>
            <%= link_to help_path,
                  title: "Help",
                  aria: { label: "Help" },
                  class: "hidden sm:inline-flex items-center justify-center w-9 h-9 mr-1 rounded-md text-stone-500 hover:text-stone-900 hover:bg-stone-100 transition #{"text-stone-900 bg-stone-100" if controller_name == "help"}" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.5M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z"/>
              </svg>
            <% end %>
            <%# show_mobile_menu turns on the Rails Blocks navbar's
                built-in hamburger (sm:hidden in its own template).
                Tapping it opens the mobile-menu-content panel
                populated below — the only way to reach
                Library/Authors/Series/Kobo/Shelves/Lists/Help on a
                phone, since the inline nav above is hidden. The
                user-menu item is mobile_hidden because Setup/Tools/
                Sign out are duplicated inside the mobile menu. %>
            <%= render "shared/components/navbar/navbar",
                  variant: "transparent",
                  show_mobile_menu: true,
                  mobile_menu_content_id: "mobile-menu-content",
                  items: [
                    { label: render("tasks/tray_trigger_label"), dropdown: true, content_id: "tasks-tray", align: "end" },
                    { label: current_user.display_name,         dropdown: true, content_id: "user-menu",   align: "end", mobile_hidden: true }
                  ],
                  dropdown_contents: [
                    { id: "tasks-tray", width: "w-80", content: capture { render "tasks/tray", tasks: Task.visible.order(:created_at) } },
                    { id: "user-menu",  width: "w-56", content: capture { render "layouts/user_menu_content" } },
                    { id: "mobile-menu-content", width: "w-72", content: capture { render "layouts/mobile_menu_content", on_kobo_count: on_kobo_count } }
                  ] %>
          <% end %>
        </div>
      </div>
    </header>

    <%= turbo_stream_from "tasks:active" %>
    <%= render "tasks/active_list", tasks: Task.visible.order(:created_at) %>

    <main class="container mx-auto px-6 py-8">
      <% flash.each do |type, msg| %>
        <div class="mb-4 px-4 py-2 rounded <%= type.to_s == "alert" ? "bg-red-50 text-red-800 border border-red-200" : "bg-emerald-50 text-emerald-800 border border-emerald-200" %>">
          <%= msg %>
        </div>
      <% end %>
      <%= yield %>
    </main>

    <footer class="container mx-auto px-6 py-6 text-xs text-stone-400 text-center">
      <% sha = Rails.configuration.x.git_sha %>
      <% short = Rails.configuration.x.git_sha_short %>
      <% if sha.present? && sha != "dev" && sha != "unknown" %>
        <%= link_to short, "https://github.com/mm53bar/tsundoku/commit/#{sha}",
              target: "_blank",
              rel: "noopener",
              class: "font-mono hover:text-stone-600" %>
      <% else %>
        <span class="font-mono"><%= short %></span>
      <% end %>
    </footer>
  </body>
</html>
