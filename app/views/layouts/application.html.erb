<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Tsundoku" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Tsundoku">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-stone-50 text-stone-900 min-h-screen">
    <header class="border-b border-stone-200 bg-white">
      <div class="container mx-auto px-6 py-4 flex items-center justify-between">
        <%= link_to root_path, class: "flex items-center gap-2.5 text-xl font-semibold tracking-tight" do %>
          <%= image_tag "/favicon-96.png", alt: "", class: "w-10 h-10" %>
          <span>Tsundoku</span>
        <% end %>
        <div class="text-sm text-stone-600 flex items-center gap-4">
          <% if signed_in? %>
            <div data-controller="dropdown" class="relative">
              <button type="button"
                      data-action="dropdown#toggle"
                      class="flex items-center gap-1.5 text-stone-700 hover:text-stone-900 cursor-pointer">
                <span><%= current_user.display_name %></span>
                <svg class="w-4 h-4 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div data-dropdown-target="menu"
                   class="hidden absolute right-0 mt-2 w-56 bg-white border border-stone-200 rounded-md shadow-lg z-20 overflow-hidden">
                <div class="px-3 py-2 border-b border-stone-100">
                  <p class="text-sm font-medium text-stone-900"><%= current_user.display_name %></p>
                  <% if current_user.email.present? %>
                    <p class="text-xs text-stone-500 truncate"><%= current_user.email %></p>
                  <% end %>
                  <% if current_user.admin? %>
                    <p class="mt-1.5 inline-block text-xs uppercase tracking-wider text-amber-700 font-semibold">Admin</p>
                  <% end %>
                </div>
                <%= button_to sign_out_path, method: :delete,
                      form: { class: "block" },
                      class: "block w-full text-left px-3 py-2 text-sm text-stone-700 hover:bg-stone-50 cursor-pointer" do %>
                  Sign out
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </header>

    <%= turbo_stream_from "tasks:active" %>
    <%= render "tasks/active_list", tasks: Task.visible.order(:created_at) %>

    <main class="container mx-auto px-6 py-8">
      <% flash.each do |type, msg| %>
        <div class="mb-4 px-4 py-2 rounded <%= type.to_s == "alert" ? "bg-red-50 text-red-800 border border-red-200" : "bg-emerald-50 text-emerald-800 border border-emerald-200" %>">
          <%= msg %>
        </div>
      <% end %>
      <%= yield %>
    </main>

    <footer class="container mx-auto px-6 py-6 text-xs text-stone-400 text-center">
      <% sha = Rails.configuration.x.git_sha %>
      <% short = Rails.configuration.x.git_sha_short %>
      <% if sha.present? && sha != "dev" && sha != "unknown" %>
        <%= link_to short, "https://github.com/mm53bar/tsundoku/commit/#{sha}",
              target: "_blank",
              rel: "noopener",
              class: "font-mono hover:text-stone-600" %>
      <% else %>
        <span class="font-mono"><%= short %></span>
      <% end %>
    </footer>
  </body>
</html>
