<!DOCTYPE html>
<html>
  <head>
    <title><%= safe_join([ content_for(:title).presence, "Tsundoku" ].compact, " · ") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Tsundoku">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-stone-50 text-stone-900 min-h-screen">
    <header class="border-b border-stone-200 bg-white">
      <div class="container mx-auto px-6 py-4 flex items-center justify-between gap-6">
        <div class="flex items-center gap-8">
          <%= link_to root_path, class: "flex items-center gap-2.5 text-xl font-semibold tracking-tight" do %>
            <%= image_tag "/favicon-96.png", alt: "", class: "w-10 h-10" %>
            <span>Tsundoku</span>
          <% end %>
          <% if signed_in? %>
            <% reading_count = current_user.readings.where(status: :currently_reading).count %>
            <nav class="hidden sm:flex items-center gap-5 text-sm text-stone-600">
              <%= link_to "Library", root_path, class: "hover:text-stone-900 #{"text-stone-900 font-medium" if controller_name == "library" && params[:filter].blank?}" %>
              <% if reading_count.positive? %>
                <%= link_to root_path(filter: "currently_reading"),
                      class: "hover:text-stone-900 inline-flex items-center gap-1 #{"text-stone-900 font-medium" if params[:filter] == "currently_reading"}" do %>
                  Reading
                  <span class="inline-flex items-center justify-center min-w-[1.25rem] px-1 text-xs rounded-full bg-amber-100 text-amber-800"><%= reading_count %></span>
                <% end %>
              <% end %>
              <%= link_to "Authors", authors_path, class: "hover:text-stone-900 #{"text-stone-900 font-medium" if controller_name == "authors"}" %>
              <%= link_to "Series",  series_index_path, class: "hover:text-stone-900 #{"text-stone-900 font-medium" if controller_name == "series"}" %>
              <%= link_to "Shelves", shelves_path, class: "hover:text-stone-900 #{"text-stone-900 font-medium" if controller_name == "shelves"}" %>
              <%= link_to "Lists",   lists_path, class: "hover:text-stone-900 #{"text-stone-900 font-medium" if controller_name == "lists"}" %>
              <% if current_user&.can_ingest? %>
                <%= link_to "Ingest",  ingest_index_path, class: "hover:text-stone-900 #{"text-stone-900 font-medium" if controller_name == "ingest"}" %>
              <% end %>
            </nav>
          <% end %>
        </div>
        <% if signed_in? %>
          <div class="flex-1 max-w-md hidden sm:block"
               data-controller="navbar-search"
               data-navbar-search-url-value="<%= search_path %>">
            <div class="relative">
              <input type="search"
                     placeholder="Search books..."
                     autocomplete="off"
                     data-navbar-search-target="input"
                     data-action="input->navbar-search#query focus->navbar-search#focus keydown->navbar-search#keydown"
                     class="w-full rounded-md border border-stone-200 bg-stone-50 px-3 py-1.5 text-sm placeholder:text-stone-400 focus:bg-white focus:border-stone-400 focus:outline-none">
              <div data-navbar-search-target="dropdown"
                   hidden
                   class="absolute top-full left-0 right-0 mt-1 bg-white border border-stone-200 rounded-md shadow-lg z-50 max-h-96 overflow-y-auto">
                <turbo-frame id="navbar-search-results" data-navbar-search-target="frame"></turbo-frame>
              </div>
            </div>
          </div>
        <% end %>
        <div class="flex items-center">
          <% if signed_in? %>
            <%= render "shared/components/navbar/navbar",
                  variant: "transparent",
                  show_mobile_menu: false,
                  items: [
                    { label: render("tasks/tray_trigger_label"), dropdown: true, content_id: "tasks-tray", align: "end" },
                    { label: current_user.display_name,         dropdown: true, content_id: "user-menu",   align: "end" }
                  ],
                  dropdown_contents: [
                    { id: "tasks-tray", width: "w-80", content: capture { render "tasks/tray", tasks: Task.visible.order(:created_at) } },
                    { id: "user-menu",  width: "w-56", content: capture { render "layouts/user_menu_content" } }
                  ] %>
          <% end %>
        </div>
      </div>
    </header>

    <%= turbo_stream_from "tasks:active" %>
    <%= render "tasks/active_list", tasks: Task.visible.order(:created_at) %>

    <main class="container mx-auto px-6 py-8">
      <% flash.each do |type, msg| %>
        <div class="mb-4 px-4 py-2 rounded <%= type.to_s == "alert" ? "bg-red-50 text-red-800 border border-red-200" : "bg-emerald-50 text-emerald-800 border border-emerald-200" %>">
          <%= msg %>
        </div>
      <% end %>
      <%= yield %>
    </main>

    <footer class="container mx-auto px-6 py-6 text-xs text-stone-400 text-center">
      <% sha = Rails.configuration.x.git_sha %>
      <% short = Rails.configuration.x.git_sha_short %>
      <% if sha.present? && sha != "dev" && sha != "unknown" %>
        <%= link_to short, "https://github.com/mm53bar/tsundoku/commit/#{sha}",
              target: "_blank",
              rel: "noopener",
              class: "font-mono hover:text-stone-600" %>
      <% else %>
        <span class="font-mono"><%= short %></span>
      <% end %>
    </footer>
  </body>
</html>
