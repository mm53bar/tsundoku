<% content_for :title, "Dev sign-in" %>

<div class="max-w-md mx-auto mt-16 bg-white border border-stone-200 rounded-lg p-8 shadow-sm">
  <h1 class="text-2xl font-semibold mb-2">Dev sign-in</h1>
  <p class="text-stone-600 mb-6 text-sm">Stand-in for the proxy's <code>Remote-User</code> header in local development. Any username creates or signs you in as that user.</p>

  <%= form_with url: dev_login_path, method: :post, local: true, class: "flex gap-2" do |f| %>
    <%= f.text_field :as, value: "alex", required: true,
          class: "flex-1 border border-stone-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-stone-400" %>
    <%= f.submit "Sign in", class: "bg-stone-900 text-white rounded px-4 py-2 hover:bg-stone-700 cursor-pointer" %>
  <% end %>

  <% if @existing_users.any? %>
    <div class="mt-6 pt-6 border-t border-stone-200">
      <p class="text-xs uppercase tracking-wider text-stone-500 mb-2">Existing users</p>
      <ul class="text-sm text-stone-700 space-y-1">
        <% @existing_users.each do |u| %>
          <li><%= u.name %> &middot; <span class="text-stone-500"><%= u.username %></span> &middot; <%= u.role %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>
