<% content_for :title, "Settings" %>

<div class="max-w-2xl">
  <h1 class="text-3xl font-semibold tracking-tight text-stone-900 mb-2">Settings</h1>
  <p class="text-sm text-stone-500 mb-8">
    Integration URLs for this Tsundoku instance. Leave a field blank to fall back
    to its environment variable (if one is set) or to turn the integration off.
  </p>

  <%= form_with model: @setting, url: settings_path, method: :patch, class: "space-y-6" do |f| %>
    <% if @setting.errors.any? %>
      <div class="rounded-md bg-red-50 border border-red-200 p-3 text-sm text-red-800">
        <%= pluralize(@setting.errors.count, "error") %> prevented saving the settings.
      </div>
    <% end %>

    <div>
      <%= f.label :shelfmark_url, "Shelfmark URL", class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.url_field :shelfmark_url, placeholder: "https://shelfmark.example.com",
            class: "w-full rounded-md border border-stone-300 px-3 py-2 text-sm focus:border-amber-600 focus:ring-amber-600 focus:outline-none" %>
      <p class="mt-1 text-xs text-stone-500">
        When set, "Find via Shelfmark" links appear next to books that aren't in your library yet.
      </p>
    </div>

    <div>
      <%= f.label :authelia_logout_url, "Authelia logout URL", class: "block text-sm font-medium text-stone-700 mb-1" %>
      <%= f.url_field :authelia_logout_url, placeholder: "https://auth.example.com/logout",
            class: "w-full rounded-md border border-stone-300 px-3 py-2 text-sm focus:border-amber-600 focus:ring-amber-600 focus:outline-none" %>
      <p class="mt-1 text-xs text-stone-500">
        Where "Sign out" redirects to end the SSO session. Blank → returns to the home page.
      </p>
    </div>

    <%= f.submit "Save settings",
          class: "inline-flex items-center px-4 py-2 rounded-md bg-amber-600 text-white text-sm font-medium hover:bg-amber-700 cursor-pointer" %>
  <% end %>
</div>
