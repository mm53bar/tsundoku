<% content_for :title, "Re-import · #{@list.name}" %>

<div class="mb-6">
  <%= link_to @list, class: "inline-flex items-center gap-1 text-sm text-stone-600 hover:text-stone-900" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    <%= @list.name %>
  <% end %>
</div>

<h1 class="text-2xl font-semibold tracking-tight text-stone-900 mb-1">Re-import entries</h1>
<p class="text-sm text-stone-500 mb-6 max-w-2xl">
  Paste a fresh copy of the list below. Tsundoku will show you what would change before applying anything — added entries, removed entries, and how many stay the same. The current list (<%= pluralize(@list.list_entries.size, "entry") %>) is untouched until you confirm.
</p>

<%= form_with url: reimport_list_path(@list), method: :post, local: true, class: "space-y-5 max-w-2xl" do %>
  <div>
    <%= label_tag "list[entries_text]", "New entries", class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= text_area_tag "list[entries_text]", nil,
          rows: 14,
          required: true,
          placeholder: "Paste JSON or one-book-per-line text…",
          class: "block w-full rounded-md border border-stone-300 px-3 py-2 text-sm font-mono shadow-sm focus:border-amber-600 focus:ring-amber-600 focus:outline-none" %>
  </div>

  <div class="flex items-center gap-3 border-t border-stone-200 pt-5">
    <%= submit_tag "Preview changes",
          class: "inline-flex items-center px-4 py-2 bg-stone-900 text-white text-sm font-medium rounded-md hover:bg-stone-700 transition cursor-pointer" %>
    <%= link_to "Cancel", @list, class: "text-sm text-stone-600 hover:text-stone-900" %>
  </div>
<% end %>
