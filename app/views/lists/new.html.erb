<% content_for :title, "New list" %>

<div class="mb-6">
  <%= link_to lists_path, class: "inline-flex items-center gap-1 text-sm text-stone-600 hover:text-stone-900" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Lists
  <% end %>
</div>

<h1 class="text-2xl font-semibold tracking-tight text-stone-900 mb-2">New list</h1>
<p class="text-sm text-stone-500 mb-6 max-w-2xl">
  Paste book entries below. Tsundoku will match each one against your library and mark
  the ones you already have. For sources that don't expose a clean format, ask an LLM
  (Claude/ChatGPT) to convert them — see the format hints below the box.
</p>

<%= form_with model: @list, url: lists_path, method: :post, local: true, class: "space-y-5 max-w-2xl" do |f| %>
  <div>
    <%= f.label :name, "List name", class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= f.text_field :name,
          required: true,
          placeholder: "e.g. Oprah's Book Club",
          class: "block w-full rounded-md border border-stone-300 px-3 py-2 text-sm shadow-sm focus:border-amber-600 focus:ring-amber-600 focus:outline-none" %>
  </div>

  <div>
    <%= f.label :source_url, "Source URL (optional)", class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= f.text_field :source_url,
          placeholder: "https://www.oprah.com/book-list/oprahs-book-club-the-complete-list",
          class: "block w-full rounded-md border border-stone-300 px-3 py-2 text-sm shadow-sm focus:border-amber-600 focus:ring-amber-600 focus:outline-none" %>
  </div>

  <div>
    <%= f.label :description, "Description (optional)", class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= f.text_area :description,
          rows: 2,
          class: "block w-full rounded-md border border-stone-300 px-3 py-2 text-sm shadow-sm focus:border-amber-600 focus:ring-amber-600 focus:outline-none" %>
  </div>

  <div>
    <%= label_tag "list[entries_text]", "Entries", class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= text_area_tag "list[entries_text]", nil,
          rows: 14,
          required: true,
          placeholder: %(Paste a JSON array or one book per line — Tsundoku is lenient about format:

[{"title":"1984","author":"George Orwell"}, ...]

# or:
1984 by George Orwell
Animal Farm — George Orwell
Brave New World by Aldous Huxley),
          class: "block w-full rounded-md border border-stone-300 px-3 py-2 text-sm font-mono shadow-sm focus:border-amber-600 focus:ring-amber-600 focus:outline-none" %>
    <details class="mt-2 text-xs text-stone-500">
      <summary class="cursor-pointer hover:text-stone-700">Tips for using an LLM to format a list</summary>
      <div class="mt-2 space-y-2 pl-3 border-l-2 border-stone-200">
        <p>
          Find the list anywhere (a blog post, a Wikipedia article, even a photo of a printed page).
          Paste the source into Claude or ChatGPT with a prompt like:
        </p>
        <pre class="bg-stone-100 p-2 rounded text-xs whitespace-pre-wrap">Parse this list into a JSON array of objects with "title" and "author" keys. Preserve order. Skip section headers. Normalize author names to "First Last" form.</pre>
        <p>Then paste the LLM's JSON output into the box above.</p>
        <p>
          Tsundoku also accepts plain text — "Title by Author", "Title — Author", or just titles.
          Numbered prefixes ("1. ", "12) ") and lines starting with # are stripped.
        </p>
      </div>
    </details>
  </div>

  <div class="flex items-center gap-3 border-t border-stone-200 pt-5">
    <%= f.submit "Create list",
          class: "inline-flex items-center px-4 py-2 bg-stone-900 text-white text-sm font-medium rounded-md hover:bg-stone-700 transition cursor-pointer" %>
    <%= link_to "Cancel", lists_path, class: "text-sm text-stone-600 hover:text-stone-900" %>
  </div>
<% end %>
