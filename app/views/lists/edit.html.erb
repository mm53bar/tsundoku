<% content_for :title, "Edit · #{@list.name}" %>

<div class="mb-6">
  <%= link_to @list, class: "inline-flex items-center gap-1 text-sm text-stone-600 hover:text-stone-900" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    <%= @list.name %>
  <% end %>
</div>

<h1 class="text-2xl font-semibold tracking-tight text-stone-900 mb-1">Edit list</h1>
<p class="text-sm text-stone-500 mb-6">Update the list's metadata. To add or remove entries, do that from the list itself.</p>

<%= form_with model: @list, local: true, class: "space-y-5 max-w-2xl" do |f| %>
  <div>
    <%= f.label :name, "List name", class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= f.text_field :name,
          required: true,
          class: "block w-full rounded-md border border-stone-300 px-3 py-2 text-sm shadow-sm focus:border-amber-600 focus:ring-amber-600 focus:outline-none" %>
  </div>

  <div>
    <%= f.label :source_url, "Source URL (optional)", class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= f.text_field :source_url,
          class: "block w-full rounded-md border border-stone-300 px-3 py-2 text-sm shadow-sm focus:border-amber-600 focus:ring-amber-600 focus:outline-none" %>
  </div>

  <div>
    <%= f.label :description, "Description (optional)", class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= f.text_area :description,
          rows: 3,
          class: "block w-full rounded-md border border-stone-300 px-3 py-2 text-sm shadow-sm focus:border-amber-600 focus:ring-amber-600 focus:outline-none" %>
  </div>

  <div class="flex items-center gap-3 border-t border-stone-200 pt-5">
    <%= f.submit "Save",
          class: "inline-flex items-center px-4 py-2 bg-stone-900 text-white text-sm font-medium rounded-md hover:bg-stone-700 transition cursor-pointer" %>
    <%= link_to "Cancel", @list, class: "text-sm text-stone-600 hover:text-stone-900" %>
  </div>
<% end %>
