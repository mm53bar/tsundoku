<%# Locals: book (required), starred (Boolean — is this book on the
    current user's Starred shelf?).
    Single-tap button that toggles Starred shelf membership. The whole
    element is dom_id'd so toggle_star.turbo_stream.erb can replace it
    in-place. Lives at top-left of the book cover (sibling of the
    cover link), counterpart to the `+` button at top-right that opens
    the shelf picker. %>
<%= tag.div id: dom_id(book, :star_button), class: "contents" do %>
  <%= button_to toggle_star_book_path(book),
        method: :post,
        title:  starred ? "Remove from Starred" : "Add to Starred",
        aria:   { label: starred ? "Remove from Starred shelf" : "Add to Starred shelf" },
        form:   { class: "inline" },
        class:  starred ?
          "inline-flex items-center justify-center w-6 h-6 rounded-full bg-amber-500 hover:bg-amber-600 focus:bg-amber-600 border border-amber-600 text-white shadow-sm transition cursor-pointer" :
          "inline-flex items-center justify-center w-6 h-6 rounded-full bg-white/85 hover:bg-white focus:bg-white border border-stone-300 text-stone-500 hover:text-amber-600 shadow-sm transition cursor-pointer" do %>
    <% if starred %>
      <%# Filled star %>
      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 2l2.998 6.97L22 9.97l-5.5 5.06L18 22l-6-3.7L6 22l1.5-6.97L2 9.97l7.002-1.0L12 2z"/>
      </svg>
    <% else %>
      <%# Outline star %>
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 2l2.998 6.97L22 9.97l-5.5 5.06L18 22l-6-3.7L6 22l1.5-6.97L2 9.97l7.002-1.0L12 2z"/>
      </svg>
    <% end %>
  <% end %>
<% end %>
