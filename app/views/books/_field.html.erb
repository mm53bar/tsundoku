<%
  has_proposal = proposed.present? && proposed.to_s.strip != current.to_s.strip
  controller_attr = has_proposal ? "suggestion" : nil
  target_attr     = has_proposal ? "input" : nil
%>
<div data-controller="<%= controller_attr %>" data-suggestion-proposed-value="<%= proposed.to_s %>">
  <label for="<%= id %>" class="block text-sm font-medium text-stone-700 mb-1"><%= label %></label>

  <% case input_type %>
  <% when :text_area %>
    <textarea name="<%= name %>"
              id="<%= id %>"
              data-suggestion-target="<%= target_attr %>"
              rows="6"
              class="block w-full rounded-md border border-stone-300 px-3 py-2 text-sm shadow-sm focus:border-amber-600 focus:ring-amber-600 focus:outline-none"><%= current %></textarea>
  <% when :date_field %>
    <input type="date"
           name="<%= name %>"
           id="<%= id %>"
           data-suggestion-target="<%= target_attr %>"
           value="<%= current %>"
           class="block w-full rounded-md border border-stone-300 px-3 py-2 text-sm shadow-sm focus:border-amber-600 focus:ring-amber-600 focus:outline-none">
  <% else %>
    <input type="text"
           name="<%= name %>"
           id="<%= id %>"
           data-suggestion-target="<%= target_attr %>"
           value="<%= current %>"
           class="block w-full rounded-md border border-stone-300 px-3 py-2 text-sm shadow-sm focus:border-amber-600 focus:ring-amber-600 focus:outline-none">
  <% end %>

  <% if has_proposal %>
    <div class="mt-2 flex items-start gap-3 bg-amber-50 border border-amber-200 rounded-md px-3 py-2">
      <div class="flex-1 min-w-0 text-sm">
        <p class="text-xs uppercase tracking-wider text-amber-700 font-semibold mb-1">Hardcover suggests</p>
        <p class="text-stone-800 whitespace-pre-wrap break-words"><%= truncate(proposed.to_s, length: 400) %></p>
      </div>
      <button type="button"
              data-action="suggestion#apply"
              class="shrink-0 text-xs px-2 py-1 bg-amber-600 text-white rounded hover:bg-amber-700 cursor-pointer">
        Use this
      </button>
    </div>
  <% end %>
</div>
