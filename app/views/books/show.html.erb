<% content_for :title, @book.title %>

<div class="mb-6">
  <%= link_to root_path, class: "inline-flex items-center gap-1 text-sm text-stone-600 hover:text-stone-900" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Library
  <% end %>
</div>

<div class="grid grid-cols-1 md:grid-cols-[16rem_1fr] lg:grid-cols-[20rem_1fr] gap-8 lg:gap-12 items-start">
  <div>
    <div class="aspect-[2/3] bg-stone-200 rounded-lg overflow-hidden shadow-md ring-1 ring-stone-200/60">
      <% if @book.cover_available? %>
        <img src="<%= cover_book_path(@book, v: @book.updated_at.to_i) %>"
             alt="<%= @book.title %>"
             class="w-full h-full object-cover">
      <% else %>
        <div class="w-full h-full flex items-center justify-center p-6 bg-gradient-to-br from-stone-100 to-stone-200">
          <span class="text-center text-sm font-medium text-stone-700"><%= @book.title %></span>
        </div>
      <% end %>
    </div>
  </div>

  <div>
    <div class="flex items-start justify-between gap-4">
      <h1 class="text-3xl font-semibold tracking-tight text-stone-900"><%= @book.title %></h1>

      <% if signed_in? %>
        <div class="shrink-0 flex items-center gap-2">
          <%= link_to download_book_path(@book),
                class: "inline-flex items-center gap-1.5 px-3 py-1.5 bg-white border border-stone-300 text-stone-700 text-sm font-medium rounded-md hover:bg-stone-50 transition" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5m0 0l5-5m-5 5V4"/>
            </svg>
            Download
          <% end %>

          <% if current_user.admin? %>
            <% pending_task    = Task.pending_review.where(kind: "metadata_enrichment", subject: @book).order(:created_at).last %>
            <% enrichment_running = Task.active.where(kind: "metadata_enrichment", subject: @book).exists? %>
            <% if pending_task %>
              <%= link_to edit_book_path(@book, from_task: pending_task.id),
                    data: { turbo_prefetch: false },
                    class: "inline-flex items-center gap-1.5 px-3 py-1.5 bg-amber-600 text-white text-sm font-medium rounded-md hover:bg-amber-700 transition" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                Review suggestions
              <% end %>
            <% elsif HardcoverClient.available? && !enrichment_running %>
              <%= button_to enrich_book_path(@book),
                    method: :post,
                    class: "inline-flex items-center gap-1.5 px-3 py-1.5 bg-amber-600 text-white text-sm font-medium rounded-md hover:bg-amber-700 transition cursor-pointer" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
                </svg>
                <%= @book.enriched? ? "Re-enrich" : "Enrich" %>
              <% end %>
            <% end %>
            <%= link_to edit_book_path(@book),
                  class: "inline-flex items-center gap-1.5 px-3 py-1.5 bg-white border border-stone-300 text-stone-700 text-sm font-medium rounded-md hover:bg-stone-50 transition" do %>
              Edit
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>

    <% if @book.authors.any? %>
      <p class="text-lg text-stone-700 mt-2"><%= author_links(@book.authors, class_name: "hover:text-amber-700 hover:underline") %></p>
    <% end %>

    <% if signed_in? %>
      <div class="mt-4">
        <%= render "readings/status_picker", book: @book, reading: @reading %>
      </div>
      <% if @reading && (@reading.progress_percent.to_i.positive? || @reading.spent_reading_minutes.to_i.positive?) %>
        <div class="mt-3">
          <% if @reading.progress_percent.to_i.positive? %>
            <div class="h-1.5 w-full max-w-xs bg-stone-200 rounded-full overflow-hidden">
              <div class="h-full bg-amber-600" style="width: <%= [ @reading.progress_percent.to_i, 100 ].min %>%"></div>
            </div>
          <% end %>
          <p class="text-xs text-stone-500 mt-1.5 flex flex-wrap gap-x-3">
            <% if @reading.progress_percent.to_i.positive? %>
              <span><%= @reading.progress_percent %>% read</span>
            <% end %>
            <% if (remaining = format_reading_time(@reading.remaining_time_minutes)) %>
              <span><%= remaining %> left</span>
            <% end %>
            <% if (spent = format_reading_time(@reading.spent_reading_minutes)) %>
              <span><%= spent %> spent</span>
            <% end %>
          </p>
        </div>
      <% end %>
      <div class="mt-3">
        <%= render "shelves/chip_row", book: @book, user: current_user %>
      </div>
    <% end %>

    <% if @book.series.present? %>
      <p class="text-sm text-stone-500 italic mt-1">
        <%= render "series/link", series: @book.series, class_name: "italic hover:text-amber-700 hover:underline" %><% if @book.series_index.present? %>, book <%= @book.series_index.to_s.sub(/\.0+\z/, "") %><% end %>
      </p>
    <% end %>

    <% if @book.tags.any? %>
      <div class="flex flex-wrap gap-1.5 mt-4">
        <% @book.tags.each do |tag| %>
          <span class="px-2 py-0.5 bg-stone-100 text-stone-700 text-xs rounded-full border border-stone-200"><%= tag.name %></span>
        <% end %>
      </div>
    <% end %>

    <% if @book.lists.any? %>
      <div class="mt-3">
        <p class="text-xs uppercase tracking-wide text-stone-500 mb-1.5">On these lists</p>
        <div class="flex flex-wrap gap-1.5">
          <% @book.lists.each do |list| %>
            <%= link_to list, class: "px-2 py-0.5 bg-amber-50 text-amber-800 text-xs rounded-full border border-amber-200 hover:bg-amber-100 transition" do %>
              <%= list.name %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @book.description.present? %>
      <div class="mt-6 text-stone-700 text-sm leading-relaxed space-y-3 [&_p]:mb-3 [&_a]:underline [&_a]:text-stone-900 [&_em]:italic [&_strong]:font-semibold">
        <%= sanitize @book.description %>
      </div>
    <% end %>

    <dl class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3 text-sm border-t border-stone-200 pt-6">
      <% if @book.publisher.present? %>
        <div>
          <dt class="text-xs uppercase tracking-wide text-stone-500">Publisher</dt>
          <dd class="text-stone-800 mt-0.5"><%= @book.publisher.name %></dd>
        </div>
      <% end %>
      <% if @book.pubdate.present? && @book.pubdate.year > 1 %>
        <div>
          <dt class="text-xs uppercase tracking-wide text-stone-500">Published</dt>
          <dd class="text-stone-800 mt-0.5"><%= @book.pubdate.strftime("%B %Y") %></dd>
        </div>
      <% end %>
      <% if @book.file_format.present? %>
        <div>
          <dt class="text-xs uppercase tracking-wide text-stone-500">Format</dt>
          <dd class="text-stone-800 mt-0.5"><%= @book.file_format %></dd>
        </div>
      <% end %>
      <% if @book.added_at.present? %>
        <div>
          <dt class="text-xs uppercase tracking-wide text-stone-500">Added</dt>
          <dd class="text-stone-800 mt-0.5"><%= @book.added_at.to_date.to_fs(:long) %></dd>
        </div>
      <% end %>
      <% if @book.last_modified.present? %>
        <div>
          <dt class="text-xs uppercase tracking-wide text-stone-500">Last modified</dt>
          <dd class="text-stone-800 mt-0.5"><%= @book.last_modified.to_date.to_fs(:long) %></dd>
        </div>
      <% end %>
    </dl>

    <% identifiers = sorted_book_identifiers(@book) %>
    <% if identifiers.any? %>
      <div class="mt-6">
        <h2 class="text-xs uppercase tracking-wide text-stone-500 mb-2">Identifiers</h2>
        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-2 text-sm">
          <% identifiers.each do |bi| %>
            <div>
              <dt class="text-xs text-stone-500"><%= book_identifier_label(bi.kind) %></dt>
              <dd class="text-stone-800 font-mono mt-0.5 truncate">
                <% if (url = book_identifier_url(bi)) %>
                  <%= link_to bi.value, url, target: "_blank", rel: "noopener", class: "text-stone-900 hover:text-amber-700 underline decoration-stone-300 hover:decoration-amber-700" %>
                <% else %>
                  <%= bi.value %>
                <% end %>
              </dd>
            </div>
          <% end %>
        </dl>
      </div>
    <% end %>
  </div>
</div>
