<%# Locals: book (required), reading (optional — per-user Reading
    record for the progress strip; pass nil when the card is rendered
    outside a user-scoped context), all_shelves (optional — the user's
    shelves preloaded by the caller), member_ids (optional — the
    book's current shelf-id memberships), starred_shelf_id (optional —
    pass the user's Starred shelf id so the card can derive the star
    state without a per-card query). %>
<% reading ||= nil %>
<% starred = local_assigns[:starred_shelf_id].present? && local_assigns[:member_ids]&.include?(local_assigns[:starred_shelf_id]) %>
<div class="group flex flex-col"
     data-library-filter-target="card"
     data-searchable="<%= book_searchable_text(book) %>">
  <div class="relative">
    <%= link_to book_path(book), class: "block" do %>
      <div class="relative aspect-[2/3] bg-stone-200 rounded-md overflow-hidden shadow-sm group-hover:shadow-xl transition-shadow ring-1 ring-stone-200/60">
        <% if book.assets.cover_available? %>
          <img src="<%= cover_book_path(book, v: book.updated_at.to_i) %>"
               alt="<%= book.title %>"
               loading="lazy"
               class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300">
        <% else %>
          <div class="w-full h-full flex items-center justify-center p-3 bg-gradient-to-br from-stone-100 to-stone-200">
            <span class="text-center text-xs font-medium text-stone-700 line-clamp-6"><%= book.title %></span>
          </div>
        <% end %>

        <% if reading&.in_progress? %>
          <%# Always-visible track on currently-reading cards so the user sees
              "in progress" at a glance even when the fill is <2px wide. White
              track with a stone outline carries enough contrast against any
              cover; the amber fill stays the same. %>
          <div class="absolute bottom-0 left-0 right-0 h-1.5 bg-white/85 border-t border-stone-300/70">
            <div class="h-full bg-amber-500" style="width: <%= [ reading.progress_percent.to_i, 100 ].min %>%"></div>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Star (top-left): toggles the user's Starred shelf in a single
        tap. Sibling of the cover link (a button in an anchor is
        invalid HTML). %>
    <% if signed_in? %>
      <div class="absolute top-2 left-2 z-10">
        <%= render "books/star_button", book: book, starred: starred %>
      </div>
    <% end %>

    <%# Shelf picker (top-right): opens the popover with checkboxes
        for every shelf the user owns (including Starred). Two corners
        gives clear spatial separation between "quick star toggle"
        and "manage every shelf for this book." %>
    <% if signed_in? %>
      <div class="absolute top-2 right-2 z-10">
        <%= render "shelves/quick_add",
              book: book,
              user: current_user,
              **local_assigns.slice(:all_shelves, :member_ids, :starred_shelf_id) %>
      </div>
    <% end %>
  </div>

  <div class="mt-2 px-0.5">
    <%= link_to book.title, book_path(book),
          class: "block text-sm font-medium text-stone-900 leading-snug line-clamp-2 group-hover:text-stone-700" %>

    <% if book.authors.any? %>
      <p class="text-xs text-stone-500 mt-1 line-clamp-1"><%= author_links(book.authors) %></p>
    <% end %>

    <% if book.series.present? %>
      <p class="text-xs text-stone-400 mt-1 italic line-clamp-1">
        <%= render "series/link", series: book.series, class_name: "italic hover:text-amber-700 hover:underline" %><% if book.series_index.present? %> #<%= book.series_index.to_s.sub(/\.0+\z/, "") %><% end %>
      </p>
    <% end %>
  </div>
</div>
