<% content_for :title, @filter == "on_kobo" ? "On your Kobo" : "Library" %>

<div class="flex items-end justify-between gap-4 mb-6">
  <div>
    <h1 class="text-3xl font-semibold tracking-tight">
      <%= @filter == "on_kobo" ? "On your Kobo" : "Library" %>
    </h1>
    <p class="text-stone-600 text-sm mt-1" data-library-filter-target="count">
      <%= @books.size %>
    </p>
  </div>

</div>

<div data-controller="library-filter">
  <% if @books.any? %>
    <div class="mb-6 flex flex-col sm:flex-row gap-3 sm:items-center">
      <div class="relative flex-1">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M10 18a8 8 0 100-16 8 8 0 000 16z"/>
        </svg>
        <input type="search"
               data-library-filter-target="input"
               data-action="input->library-filter#filter"
               placeholder="Search by title, author, or series…"
               autocomplete="off"
               class="w-full pl-10 pr-10 py-2 text-sm rounded-md border border-stone-300 bg-white focus:border-amber-600 focus:ring-amber-600 focus:outline-none">
        <button type="button"
                data-action="library-filter#clear"
                class="absolute right-2 top-1/2 -translate-y-1/2 p-1 text-stone-400 hover:text-stone-700 cursor-pointer">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <%= form_with url: root_path, method: :get, local: true, class: "shrink-0" do |f| %>
        <label class="text-sm text-stone-600 inline-flex items-center gap-2">
          Sort:
          <%= f.select :sort,
                [ [ "Title", "title" ], [ "Recently added", "recently_added" ] ],
                { selected: @sort },
                onchange: "this.form.requestSubmit()",
                class: "py-2 px-2 text-sm rounded-md border border-stone-300 bg-white focus:border-amber-600 focus:ring-amber-600 focus:outline-none cursor-pointer" %>
        </label>
      <% end %>
    </div>
  <% end %>

  <% if @books.empty? %>
    <div class="bg-white border border-stone-200 rounded-lg p-12 text-center text-stone-600">
      <p class="text-lg font-medium text-stone-800 mb-2">No books yet.</p>
      <% if @calibre_db_available %>
        <p class="text-sm">A Calibre <code>metadata.db</code> was detected in your library directory.</p>
        <%= link_to "Set up your library →", setup_path,
              class: "inline-block mt-4 text-amber-700 hover:text-amber-800 underline" %>
      <% else %>
        <p class="text-sm">Drop a Calibre library into the configured library directory, then visit
          <%= link_to "Setup", setup_path, class: "underline hover:text-stone-900" %>
          to import it.
        </p>
      <% end %>
    </div>
  <% else %>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-6">
      <% @books.each do |book| %>
        <%= render "books/card",
              book: book,
              reading: @readings_by_book_id[book.id],
              all_shelves: @user_shelves,
              member_ids: @shelf_member_ids_by_book[book.id],
            starred_shelf_id: @starred_shelf_id %>
      <% end %>
    </div>

    <div data-library-filter-target="empty" hidden class="mt-6 bg-white border border-stone-200 rounded-lg p-8 text-center text-stone-600">
      <p class="text-sm">No books match your search.</p>
      <button type="button"
              data-action="library-filter#clear"
              class="mt-3 text-sm text-amber-700 hover:text-amber-800 underline cursor-pointer">
        Clear filter
      </button>
    </div>
  <% end %>
</div>
