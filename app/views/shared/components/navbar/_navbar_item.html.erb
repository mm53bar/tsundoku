<% label ||= "" %>
<% href ||= nil %>
<% dropdown ||= false %>
<% content_id ||= nil %>
<% align ||= "center" %>
<% mobile_hidden ||= false %>
<% item_classes ||= nil %>
<% unique_id ||= SecureRandom.hex(4) %>

<%
  # Build li classes
  li_base = mobile_hidden ? "hidden sm:block" : ""
  li_classes = [li_base, item_classes].compact.reject(&:empty?).join(" ")

  # Common classes
  link_classes = "block rounded-md px-3 py-2 text-sm font-medium text-neutral-700 no-underline select-none hover:bg-neutral-100 dark:text-neutral-300 dark:hover:bg-neutral-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-neutral-600 dark:focus-visible:outline-neutral-200"

  trigger_classes = "group flex items-center gap-1 rounded-md px-3 py-2 text-sm font-medium text-neutral-700 select-none hover:bg-neutral-100 dark:text-neutral-300 dark:hover:bg-neutral-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-neutral-600 dark:focus-visible:outline-neutral-200"
%>

<li class="<%= li_classes %>">
  <% if dropdown %>
    <button
      type="button"
      data-navbar-target="trigger"
      data-content-id="<%= content_id %>"
      aria-controls="<%= content_id %>"
      aria-expanded="false"
      data-align="<%= align %>"
      data-action="click->navbar#toggleMenu pointerenter->navbar#handlePointerEnter pointermove->navbar#handlePointerMove pointerleave->navbar#handlePointerLeave keydown->navbar#handleTriggerKeydown"
      data-state="closed"
      class="<%= trigger_classes %>"
    >
      <%= label %>
      <svg xmlns="http://www.w3.org/2000/svg" class="size-2.5 transition-transform duration-200 group-data-[state=open]:rotate-180" width="12" height="12" viewBox="0 0 12 12"><g fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" stroke="currentColor"><polyline points="1.75 4.25 6 8.5 10.25 4.25"></polyline></g></svg>
    </button>
  <% else %>
    <a href="<%= href %>" class="<%= link_classes %>">
      <%= label %>
    </a>
  <% end %>
</li>
