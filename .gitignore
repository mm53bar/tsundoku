# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore key files for decrypting credentials and more.
/config/*.key


/app/assets/builds/*
!/app/assets/builds/.keep

# Bundler installs gems here when bundle config sets path=vendor/bundle.
/vendor/bundle/

# Keep the env template in the repo.
!/.env.example

# Tailwind Plus templates are licensed for use, not redistribution.
/oatmeal-taupe-instrument.zip
/oatmeal-taupe-instrument/
Gemini_Generated_Image_*.png

# Reference downloads dropped into the project root (Rails Blocks zips,
# etc). Keep them out of the repo; their licenses don't typically permit
# redistribution.
/*.zip

# CWA's data dir, when checked out locally for the migration. Contains
# personal reading history; never commit.
/calibre-web/

# Conductor: per-machine personal settings (symlinked into each workspace).
# The shared .conductor/settings.toml IS committed.
/.conductor/settings.local.toml
