# Copy to .env (gitignored) and fill in values for your host.

# UID/GID of the user that owns the library/ingest/config dirs on the host.
# Find them with: stat -c '%u:%g' /your/library/path
# Default (1000:1000) is fine for most Linux hosts; Synology shared folders
# are typically 1027:100.
UID=1027
GID=100

# Host paths to bind-mount into the container.
LIBRARY_DIR=/volume1/data/media/books
INGEST_DIR=/volume1/docker/tsundoku/ingest
CONFIG_DIR=/volume1/docker/tsundoku/config

# Optional — host path to your existing CWA config directory (the same one
# CWA itself uses at /config). When set, the kobo:import_sync_state_from_cwa
# rake task auto-discovers app.db. Leave unset on fresh installs.
# CWA_CONFIG_DIR=/volume1/docker/calibre-web

# Host port (NPM forwards 443 -> here).
HOST_PORT=3000

# Time zone (affects timestamps).
TZ=America/New_York

# Public-facing URL of the app.
APP_URL=https://tsundoku.backson.boo

# Where to send the user when they click "Sign out". Authelia ends the SSO session.
AUTHELIA_LOGOUT_URL=https://auth.backson.boo/logout

# Persistent dir holding your secrets — master.key + credentials.yml.enc —
# bind-mounted into the container (never baked into the image). Create the dir,
# copy your master.key in, then manage secrets with:
#   docker compose exec tsundoku bin/rails credentials:edit
# (Prefer env-based config instead? Set RAILS_MASTER_KEY here and it still works.)
SECRETS_DIR=/volume1/docker/tsundoku/secrets

# Hardcover API token (metadata enrichment) is no longer an env var — store it
# in encrypted credentials instead, under the key `hardcover_app_api_token`:
#   docker compose exec tsundoku bin/rails credentials:edit
# Get one from hardcover.app → Settings → API. Paste the raw JWT (no "Bearer "
# prefix; the client adds it). ~900 chars, valid one year. Optional — unset
# means Hardcover lookups are skipped. (HARDCOVER_APP_API_TOKEN env still works
# as a fallback.)

# Shelfmark base URL. When set, Tsundoku renders "Find via Shelfmark" links
# on surfaces that show books not in the local library (unmatched list
# entries, Hardcover "more by author" / "more in series" thumbs). Shelfmark
# downloads land in INGEST_DIR and AutoIngestScanJob picks them up within
# ~2 minutes. Leave unset to hide all such links.
# SHELFMARK_URL=https://shelfmark.backson.boo
